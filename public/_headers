# Cloudflare Pages Cache & Security Headers

# Hashed JS/CSS assets — cache 1 year (immutable, Vite adds hash to filename)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Images — cache 30 days
/og-image.jpg
  Cache-Control: public, max-age=2592000
/favicon.png
  Cache-Control: public, max-age=2592000
/favicon.ico
  Cache-Control: public, max-age=2592000

# Service worker — never cache (must always be fresh)
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

# Sitemap & robots — short cache so updates propagate quickly
/sitemap.xml
  Cache-Control: public, max-age=3600
/robots.txt
  Cache-Control: public, max-age=3600

# HTML — always revalidate
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Security headers — applied to all routes
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  X-XSS-Protection: 1; mode=block
