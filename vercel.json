{
  "rewrites": [
    {
      "source": "/",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(googlebot|bingbot|slurp|duckduckbot|baiduspider|yandexbot|facebookexternalhit|twitterbot|linkedinbot|discordbot|telegrambot|whatsapp|slackbot|applebot|pinterest|redditbot|semrushbot|ahrefsbot|mj12bot|petalbot|screaming frog|dotbot|rogerbot).*"
        }
      ],
      "destination": "/api/prerender?path=/"
    },
    {
      "source": "/(tool|category|tag|blog|tutorials)/:path*",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(googlebot|bingbot|slurp|duckduckbot|baiduspider|yandexbot|facebookexternalhit|twitterbot|linkedinbot|discordbot|telegrambot|whatsapp|slackbot|applebot|pinterest|redditbot|semrushbot|ahrefsbot|mj12bot|petalbot|screaming frog|dotbot|rogerbot).*"
        }
      ],
      "destination": "/api/prerender?path=/$1/:path*"
    },
    {
      "source": "/(about|browse|compare|contact|favorites|submit|privacy|terms|changelog|api-docs|advertise|site-map)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(googlebot|bingbot|slurp|duckduckbot|baiduspider|yandexbot|facebookexternalhit|twitterbot|linkedinbot|discordbot|telegrambot|whatsapp|slackbot|applebot|pinterest|redditbot|semrushbot|ahrefsbot|mj12bot|petalbot|screaming frog|dotbot|rogerbot).*"
        }
      ],
      "destination": "/api/prerender?path=/$1"
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/sitemap.xml",
      "dest": "/sitemap.xml"
    },
    {
      "src": "/robots.txt",
      "dest": "/robots.txt"
    },
    {
      "src": "/favicon.png",
      "dest": "/favicon.png"
    },
    {
      "src": "/favicon.ico",
      "dest": "/favicon.ico"
    },
    {
      "src": "/manifest.json",
      "dest": "/manifest.json"
    },
    {
      "src": "/og-image.jpg",
      "dest": "/og-image.jpg"
    },
    {
      "src": "/llms.txt",
      "dest": "/llms.txt"
    },
    {
      "src": "/sw.js",
      "dest": "/sw.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "^/$",
      "dest": "/index.html"
    },
    {
      "src": "^/(about|browse|categories|compare|contact|favorites|submit|privacy|terms|changelog|blog|tutorials|api-docs|advertise|auth|sitemap|site-map)$",
      "dest": "/index.html"
    },
    {
      "src": "^/tool/(.+)$",
      "dest": "/index.html"
    },
    {
      "src": "^/category/(.+)$",
      "dest": "/index.html"
    },
    {
      "src": "^/tag/(.+)$",
      "dest": "/index.html"
    },
    {
      "src": "^/blog/(.+)$",
      "dest": "/index.html"
    },
    {
      "src": "^/tutorials/(.+)$",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/api/404?path=$1",
      "status": 404
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ],
  "functions": {
    "api/prerender.ts": {
      "memory": 1024,
      "maxDuration": 30
    },
    "api/404.ts": {
      "memory": 128,
      "maxDuration": 5
    }
  }
}
